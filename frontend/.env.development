# Vite env yang HANYA di-load saat `npm run dev` (mode development).
# Override .env yang ada di base.
#
# Backend Laravel di-asumsi jalan di port 8000 lokal. Kalau kamu pakai port
# berbeda (mis. `php artisan serve --port=8001`), bisa override via
# `.env.development.local` (di-gitignore) tanpa edit file ini.

VITE_API_URL=http://127.0.0.1:8000/nosu
VITE_API_EMPLOYEE_URL=http://127.0.0.1:8080/api
